{
  "luci-app-nfs-server": {
    "description": "NFS Server LuCI App",
    "read": {
      "uci": [ "nfs" ],
      "file": {
        "/etc/exports": [ "read" ]
      }
    },
    "write": {
      "uci": [ "nfs" ],
      "file": {
        "/etc/exports": [ "write" ]
      },
      "ubus": {
        "service": [ "restart" ]
      }
    }
  }
}
